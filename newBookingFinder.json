      "notes": "Updates the row where key=config with new storedTimestamp. Same sheet as Read Last Timestamp."
    },
    {
      "parameters": {
        "jsCode": "const data = $('Accumulate Leads').last().json;\nconst leads = data?.accumulatedLeads || [];\nlet maxUpdated = null;\nfor (const lead of leads) {\n  const t = lead?.metadata?.updatedUtcDateTime;\n  if (t && (!maxUpdated || t > maxUpdated)) maxUpdated = t;\n}\nlet newStoredTimestamp = maxUpdated || data?.storedTimestamp || '1970-01-01T00:00:00.000Z';\n// Advance by 1 ms so the next run never sees \"equal\" timestamp (avoids skipping a booking forever)\nif (maxUpdated) {\n  const d = new Date(newStoredTimestamp);\n  d.setUTCMilliseconds(d.getUTCMilliseconds() + 1);\n  newStoredTimestamp = d.toISOString();\n}\nreturn [{ json: { key: 'config', storedTimestamp: newStoredTimestamp } }];"
      },
      "id": "ceb7b0d2-f5a5-4c60-bbc9-373a6f08771a",
      "name": "Compute Max After Loop",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2016,
        512
      ],
      "notes": "Runs only when Split In Batches (Done) fires. Reads from Accumulate Leads to avoid timestamp race."
    },
    {
      "parameters": {
        "jsCode": "const storedTimestamp = $('Accumulate Leads').last().json?.storedTimestamp || '1970-01-01T00:00:00.000Z';\nconst items = $input.all();\nconst filtered = [];\nfor (const item of items) {\n  const lead = item.json;\n  const created = lead?.metadata?.createdUtcDateTime;\n  if (created && created > storedTimestamp && lead?.type === 'BOOKING' && lead?.status === 'BOOKED') {\n    filtered.push(item);\n  }\n}\nreturn filtered;"
      },
      "id": "7be5f2d3-f2ed-448f-b9c6-4182fb8d075e",
      "name": "Filter New Bookings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1568,
        592
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $('Accumulate Leads').last().json;\nconst leads = data?.accumulatedLeads || [];\nconst storedTimestamp = data?.storedTimestamp\n  || '1970-01-01T00:00:00.000Z';\n\nconst ZONED_REGEX = /[zZ]|[+-]\\d{2}:\\d{2}$/;\n\nconst candidates = [];\n\nfor (const lead of leads) {\n  const created = lead?.metadata?.createdUtcDateTime;\n  const updated = lead?.metadata?.updatedUtcDateTime;\n\n  if (lead?.type !== 'BOOKING' || lead?.status !== 'BOOKED') continue;\n  if (!updated || !created) continue;\n  if (updated <= storedTimestamp) continue;\n  if (created > storedTimestamp) continue;\n\n  const rawCheckout = lead?.checkOutZonedDateTime;\n  if (!rawCheckout || !ZONED_REGEX.test(rawCheckout.trim())) continue;\n\n  const checkoutDate = new Date(rawCheckout.trim());\n  if (isNaN(checkoutDate.getTime())) continue;\n\n  const checkoutTimeUTC = checkoutDate.toISOString();\n  const checkoutDateOnly = checkoutTimeUTC.substring(0, 10);\n  const checkoutTimeOnly = checkoutTimeUTC.substring(11, 16);\n\n  candidates.push({\n    bookingUid: lead.uid || '',\n    propertyUid: lead.propertyUid || '',\n    newCheckOut: lead.checkOutLocalDateTime || checkoutDateOnly,\n    newCheckoutTimeUTC: checkoutTimeUTC,\n    newScheduledCleaningTimeUTC: checkoutTimeUTC,\n    newCleaningDate: checkoutDateOnly,\n    newCleaningTime: checkoutTimeOnly\n  });\n}\n\nreturn candidates.map(c => ({ json: c }));"
      },
