    {
      "parameters": {
        "jsCode": "const body = $('Receive Extended Checkout Payload').item.json.body || {};\nconst job  = $('Lookup Cleaning Job').item.json || {};\n\n// Old values captured from lookup BEFORE any update ran\nconst oldCheckoutUTC     = (job.checkoutTimeUTC          || '').toString().trim();\nconst oldCleaningTimeUTC = (job.scheduledCleaningTimeUTC || '').toString().trim();\nconst jobStatusAtUpdate  = (job.status                   || '').toString().trim();\nconst calendarEventId    = (job.calendarEventId          || '').toString().trim();\nconst cleanerId          = (job.cleanerId                || '').toString().trim();\n\nconst extensionId = (body.bookingUid || '') + '_EXT_' + Date.now();\n\nreturn [{ json: {\n  extensionId,\n  bookingUid:          body.bookingUid                   || '',\n  propertyUid:         body.propertyUid                  || '',\n  oldCheckoutUTC,\n  newCheckoutUTC:      body.newCheckoutTimeUTC           || '',\n  oldCleaningTimeUTC,\n  newCleaningTimeUTC:  body.newScheduledCleaningTimeUTC  || '',\n  detectedAtUTC:       new Date().toISOString(),\n  jobStatusAtUpdate,\n  calendarEventId,\n  cleanerId\n} }];"
      },
