      "name": "DistanceCalculation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        1056
      ],
      "notes": "Haversine: user lat/lng vs property lat/lng; return distance in meters."
    },
